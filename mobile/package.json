{
  "name": "evolum-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --tunnel --clear",
    "start:lan": "expo start --lan --clear",
    "start:local": "expo start --localhost --clear",
    "android": "expo start --android --tunnel --clear",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doctor": "expo install --check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "54.0.35",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "19.1.17",
    "typescript": "5.9.3"
  }
}
